# Copy this file to .env before running docker compose.

# Ports
FRONTEND_PORT=5173
BACKEND_PORT=8080

# External PostgreSQL
DB_HOST=192.168.20.201
DB_PORT=5432
DB_NAME=ai-req-tool
DB_USER=postgres
DB_PASSWORD=postgres

# LLM (choose one)
# OpenAI-compatible endpoint/model
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=30000

# OpenAI key
OPENAI_API_KEY=

# Auth token secret for backend JWT-like token
AUTH_TOKEN_SECRET=change-me-in-prod
